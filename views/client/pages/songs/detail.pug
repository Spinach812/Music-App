extends ../../layouts/default.pug 
include ../../mixins/box-head.pug 

block main 
  .siger-detail 
    .container.my-3 
      .row 
        .col-12 
          .inner-title #{song.title} 

          .inner-actions 
            div(class="inner-action inner-time")
              <i class="fa-regular fa-clock"></i> DD/MM/YY 
            div(class="inner-action inner-singer")
              <i class="fa-solid fa-microphone-lines"></i> #{singer.fullName} 
            div(class="inner-action inner-topic")
              <i class="fa-solid fa-music"></i> #{topic.title} 
            div(class="inner-action inner-like" button-like=song.id)
              <i class="fa-regular fa-thumbs-up"></i>
              span  #{song.like} 
            div(class="inner-action inner-heart")
              <i class="fa-regular fa-heart"></i> Song Like

          .inner-play
            .inner-avatar   
              img(song=song.avatar)
            .inner-audio 
              div(id="aplayer" data-song=song data-singer=singer)

          .inner-desc 
            .inner-label Description 
            .inner-text 
              | !{song.description}
          .inner-desc 
            .inner-label Lyrics 
            .inner-text 
              | !{song.lyric}

